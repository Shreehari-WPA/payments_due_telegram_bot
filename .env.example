# Required
TELEGRAM_BOT_TOKEN=8916015050:AAHEh8Ud4tykzu3VL8CnaZVsoXzvZCfRm6g

# Comma-separated Telegram user IDs allowed to control broadcasts.
# Run /my_id in private chat with the bot to get your ID.
MANAGER_TELEGRAM_IDS=123456789

# Local default. For PostgreSQL use:
# postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///reminder_bot.db

# Daily scheduled reminder time in Dubai time.
TIMEZONE=Asia/Dubai
DAILY_SEND_TIME=10:00

# Safety delay between group sends. Keep 1-2 seconds for 60+ groups.
SEND_DELAY_SECONDS=1.2

# Default reminder template inserted on first run.
# {greeting} is replaced at send time: literal "Good morning" for the scheduled daily send,
# or a time-of-day greeting (Good morning/afternoon/evening) for manager-initiated sends.
DEFAULT_REMINDER_MESSAGE={greeting},\n\nThis is a gentle reminder regarding the pending payment settlement.\n\nKindly arrange the payment at your earliest convenience.\n\nThank you.
